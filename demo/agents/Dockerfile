# Build context must be the repository root:
#   docker build -f demo/agents/Dockerfile -t agent-control-demo-agents:latest .

FROM python:3.12-slim AS base

WORKDIR /app

# Install pre-built SDK wheels (generated by setup.sh via scripts/build.py)
COPY demo/agents/dist/ /tmp/wheels/
RUN pip install --no-cache-dir /tmp/wheels/*.whl

# Install agent runtime dependencies
COPY demo/agents/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy all agent source files
COPY demo/agents/*.py .

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# AGENT_TYPE env var selects which agent scenarios to run
# Values: loan_underwriting | customer_support | trade_execution | aml_compliance | report_generation
ENV AGENT_TYPE=loan_underwriting

EXPOSE 8080

CMD ["python", "main.py"]
