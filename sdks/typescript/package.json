{
  "name": "agent-control",
  "version": "1.1.0",
  "private": false,
  "description": "TypeScript SDK for Agent Control",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentcontrol/agent-control.git",
    "directory": "sdks/typescript"
  },
  "bugs": {
    "url": "https://github.com/agentcontrol/agent-control/issues"
  },
  "homepage": "https://github.com/agentcontrol/agent-control/tree/main/sdks/typescript#readme",
  "keywords": [
    "agent-control",
    "ai-agents",
    "guardrails",
    "sdk",
    "typescript",
    "safety"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate": "make generate",
    "generate:check": "make generate-check",
    "speakeasy:install": "make speakeasy-install",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "dependencies": {
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "conventional-changelog-conventionalcommits": "^9.2.0",
    "eslint": "^8.57.1",
    "semantic-release": "^25.0.2",
    "tsup": "^8.3.6",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "packageManager": "pnpm@9.0.0"
}
